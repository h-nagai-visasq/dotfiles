autoload -Uz zmv
alias zmv='noglob zmv -W'

### historical backward/forward search with linehead string binded to ^P/^N
autoload history-search-end
zle -N history-beginning-search-backward-end history-search-end
zle -N history-beginning-search-forward-end history-search-end

bindkey "^p" history-beginning-search-backward-end
bindkey "^n" history-beginning-search-forward-end
bindkey "\\ep" history-beginning-search-backward-end
bindkey "\\en" history-beginning-search-forward-end

# Command history configuration
setopt hist_ignore_dups
setopt HIST_IGNORE_SPACE
setopt share_history
setopt inc_append_history

HISTFILE="$XDG_STATE_HOME"/zsh/history
mkdir -p "${HISTFILE:h}"
HISTSIZE=100000
SAVEHIST=$HISTSIZE

# starship prompt
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

# zoxide setup
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh --cmd j)"
fi

# mise setup
if command -v mise >/dev/null 2>&1; then
    eval "$(mise activate zsh)"
fi

# load aliases
source "$XDG_CONFIG_HOME"/zsh/.zshalias
if [[ -f "$HOME/.zshalias" ]]; then
    source "$HOME/.zshalias"
fi

# load local .zshrc if exists
if [[ -f "$HOME/.zshrc" ]]; then
    source "$HOME/.zshrc"
fi

# Docker & other completion directories
if [[ -d "$HOME/.docker/completions" ]]; then
    fpath=("$HOME/.docker/completions" $fpath)
fi

# load compinit exactly once
autoload -U compinit
if [[ -z ${_compinit_initialized:-} ]]; then
    compinit
    typeset -g _compinit_initialized=1
fi

if [[ -d "$XDG_CONFIG_HOME"/zsh/plugins ]]; then
    for plugin_file in "$XDG_CONFIG_HOME"/zsh/plugins/*.zsh(N); do
        source "$plugin_file"
    done
fi

source "$XDG_CONFIG_HOME"/zsh/.zinit
