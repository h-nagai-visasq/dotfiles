# Homebrew (macOS / Linux)
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
fi

# Tool-specific environment variables (XDG-aware)

## ripgrep
export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME"/rg/config

## pyenv configuration
export PYENV_ROOT=${PYENV_ROOT:-"$XDG_DATA_HOME"/pyenv}

export NODE_PATH="$XDG_DATA_HOME"/node/lib
export NODE_REPL_HISTORY="$XDG_DATA_HOME"/node/repl_history

## Node.js configuration
export NO_UPDATE_NOTIFIER=1
export NVM_DIR="$XDG_DATA_HOME"/nvm

## npm configuration
export npm_config_userconfig="$XDG_CONFIG_HOME"/npm/config
export npm_config_cache="$XDG_CACHE_HOME"/npm
export npm_config_prefix="$XDG_DATA_HOME"/npm
export npm_config_init_module="$XDG_DATA_HOME"/npm/config/npm-init.js

export NPM_CONFIG_PREFIX="$npm_config_prefix"

## Rust configuration
export RUSTUP_HOME="$XDG_DATA_HOME"/rustup
export CARGO_HOME="$XDG_DATA_HOME"/cargo

## MySQL, PostgreSQL, SQLite, MongoDB configuration
export MYSQL_HISTFILE="$XDG_DATA_HOME"/mysql/history
export SQLITE_HISTORY="$XDG_DATA_HOME"/sqlite/history
export PSQL_HISTORY="$XDG_DATA_HOME"/psql/history
export PGCLIRC="$XDG_CONFIG_HOME"/pgcli/config
export MONGO_HISTFILE="$XDG_DATA_HOME"/mongo/history


# PATH consolidation
typeset -aU path manpath
path=(
    "$PYENV_ROOT"/bin(N-/)
    "$HOME"/.local/bin(N-/)
    "$HOME"/bin(N-/)
    "$XDG_DATA_HOME"/npm/bin(N-/)
    "$XDG_DATA_HOME"/cargo/bin(N-/)
    "$XDG_DATA_HOME"/bundle/bin(N-/)
    "$HOME"/.nodebrew/current/bin(N-/)
    /usr/local/bin(N-/)
    /usr/local/sbin(N-/)
    $path
)

# Add Homebrew-provided paths when available
if command -v brew >/dev/null 2>&1; then
    typeset brew_prefix
    brew_prefix="$(brew --prefix 2>/dev/null)"
    path=(
        "$brew_prefix"/opt/mysql-client/bin(N-/)
        "$brew_prefix"/opt/coreutils/libexec/gnubin(N-/)
        "$brew_prefix"/opt/openssl@3/bin(N-/)
        "$brew_prefix"/opt/openssl/bin(N-/)
        $path
    )
    manpath=(
        "$brew_prefix"/opt/coreutils/libexec/gnuman(N-/)
        $manpath
    )
fi

# pyenv setup for login shells (init done interactively)
if command -v pyenv >/dev/null 2>&1; then
    eval "$(pyenv init --path)"
fi