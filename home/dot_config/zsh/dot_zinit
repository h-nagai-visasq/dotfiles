
typeset -g zinit_base="${XDG_DATA_HOME:-$HOME/.local/share}/zinit"

### Added by Zinit's installer
if [[ ! -f $zinit_base/bin/zinit.zsh ]]; then
    print -P "%F{33}▓▒░ %F{220}Installing DHARMA Initiative Plugin Manager (zdharma/zinit)…%f"
    command mkdir -p "$zinit_base" && command chmod g-rwX "$zinit_base"
    command git clone https://github.com/zdharma-continuum/zinit "$zinit_base/bin" && \
        print -P "%F{33}▓▒░ %F{34}Installation successful.%f%b" || \
        print -P "%F{160}▓▒░ The clone has failed.%f%b"
fi

source "$zinit_base/bin/zinit.zsh"
autoload -Uz _zinit
(( ${+_comps} )) && _comps[zinit]=_zinit

